rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidMetric(data) {
      return data.uid is string &&
             data.id is string && data.id.size() < 200 &&
             data.source is string && data.source.size() < 50 &&
             data.timestamp is string && data.timestamp.size() < 50 &&
             data.type is string && data.type.size() < 50 &&
             data.value is number &&
             (!('confidenceScore' in data) || data.confidenceScore is number || data.confidenceScore == null) &&
             (!('sourceId' in data) || data.sourceId is string || data.sourceId == null) &&
             (!('unit' in data) || data.unit is string || data.unit == null);
    }

    function isValidImportLog(data) {
      return data.uid is string &&
             data.id is string && data.id.size() < 200 &&
             data.importDate is string && data.importDate.size() < 50 &&
             data.filename is string && data.filename.size() < 500 &&
             data.status is string && data.status in ["success", "error", "partial", "processing", "warning"] &&
             data.recordsAdded is number &&
             (!('errorMessage' in data) || data.errorMessage is string || data.errorMessage == null);
    }

    function isValidActivity(data) {
      return data.uid is string &&
             data.id is string && data.id.size() < 200 &&
             data.title is string && data.title.size() < 200 &&
             data.type is string && data.type.size() < 100 &&
             data.date is string && data.date.size() < 50 &&
             data.duration is string && data.duration.size() < 50 &&
             (!('distance' in data) || data.distance is number || data.distance == null) &&
             (!('calories' in data) || data.calories is number || data.calories == null) &&
             (!('avgHeartRate' in data) || data.avgHeartRate is number || data.avgHeartRate == null) &&
             (!('maxHeartRate' in data) || data.maxHeartRate is number || data.maxHeartRate == null) &&
             (!('tss' in data) || data.tss is number || data.tss == null) &&
             (!('sourceId' in data) || data.sourceId is string || data.sourceId == null);
    }

    function isValidProfile(data) {
      return data.uid is string; // Age, weight, etc. are optional according to blueprint
    }

    // ===============================================================
    // Collections
    // ===============================================================
    
    match /metrics/{metricId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidMetric(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidMetric(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /importLogs/{logId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidImportLog(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidImportLog(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidActivity(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidActivity(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated() && userId == request.auth.uid;
      allow create: if isAuthenticated() && userId == request.auth.uid && isValidProfile(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && userId == request.auth.uid && isValidProfile(request.resource.data) && uidNotModified();
      allow delete: if false; // Profile deletion not directly allowed here
    }
  }
}
